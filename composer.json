{
  "name": "corbpie/nba-live",
  "description": "NBA live games API wrapper",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "stable",
  "authors": [
    {
      "name": "corbpie",
      "email": "contact@corbpie.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "psr/simple-cache": "^3.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Corbpie\\NBALive\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Corbpie\\NBALive\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse --memory-limit=512M"
  }
}
